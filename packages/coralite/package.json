{
  "name": "coralite",
  "version": "0.40.2",
  "description": "HTML modules static site generator",
  "type": "module",
  "keywords": [
    "static-site-generator",
    "components",
    "templates",
    "coralite",
    "blog",
    "site-engine",
    "documentation-tool"
  ],
  "homepage": "https://coralite.dev",
  "author": {
    "name": "Thomas David",
    "url": "https://thomasjackdavid.com"
  },
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/tjdavid/coralite.git",
    "directory": "packages/coralite"
  },
  "bugs": {
    "url": "https://codeberg.org/tjdavid/coralite/issues"
  },
  "license": "MPL-2.0",
  "scripts": {
    "lint:format": "eslint --cache --fix .",
    "lint": "eslint --cache .",
    "test:unit": "node --experimental-vm-modules --experimental-import-meta-resolve --test \"./tests/unit/**/*.spec.js\"",
    "test:unit:watch": "node --experimental-vm-modules --experimental-import-meta-resolve --test --watch \"./tests/unit/**/*.spec.js\"",
    "test:unit:coverage": "node --experimental-vm-modules --experimental-import-meta-resolve --experimental-test-coverage --test \"./tests/unit/**/*.spec.js\"",
    "test:e2e": "pnpm build && pnpm clean:e2e && pnpm build:html:dev && pnpm build:html:prod && playwright test",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "clean:e2e": "premove .coralite-dev && premove .coralite-prod",
    "server": "pnpm run server:dev",
    "server:dev": "node ./tests/scripts/serve.js --dir .coralite-dev --port 3000",
    "server:prod": "node ./tests/scripts/serve.js --dir .coralite-prod --port 3001",
    "build": "premove dist && pnpm build:lib && pnpm build:types",
    "build:lib": "esbuild ./lib/index.js ./lib/coralite-element.js ./lib/plugin.js ./lib/utils/core.js ./lib/utils/index.js ./lib/utils/client/inject.js --bundle --target=esnext --format=esm --outdir=dist/lib --platform=node --sourcemap --packages=external --alias:#lib=./lib/index.js --alias:#plugins=./plugins/index.js --outbase=./lib",
    "build:types": "tsc",
    "build:html:dev": "node --experimental-vm-modules ./tests/scripts/build-html.js --mode development --outDir .coralite-dev",
    "build:html:prod": "node --experimental-vm-modules ./tests/scripts/build-html.js --mode production --outDir .coralite-prod",
    "bench": "node --experimental-vm-modules ./tests/scripts/run-benchmarks.js"
  },
  "files": [
    "dist",
    "bin",
    "llms.txt"
  ],
  "bin": {
    "coralite": "bin/coralite.js"
  },
  "imports": {
    "#lib": "./lib/index.js",
    "#plugins": "./plugins/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "default": "./dist/lib/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    },
    "./utils": {
      "types": "./dist/lib/utils/index.d.ts",
      "default": "./dist/lib/utils/index.js"
    },
    "./utils/server": {
      "types": "./dist/lib/utils/server/index.d.ts",
      "default": "./dist/lib/utils/server/index.js"
    },
    "./utils/client": {
      "types": "./dist/lib/utils/client/index.d.ts",
      "default": "./dist/lib/utils/client/index.js"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.20.0",
    "@types/serialize-javascript": "^5.0.4",
    "happy-dom": "^20.10.6",
    "mitata": "^1.0.34",
    "sirv": "^3.0.2",
    "sirv-cli": "^3.0.1"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "dependencies": {
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "commander": "^13.1.0",
    "dom-serializer": "^2.0.0",
    "esbuild": "^0.25.12",
    "esbuild-plugins-node-modules-polyfill": "^1.8.1",
    "htmlparser2": "^10.1.0",
    "isomorphic-dompurify": "^3.18.0",
    "kleur": "^4.1.5",
    "p-limit": "^7.3.0",
    "postcss": "^8.5.15",
    "postcss-selector-parser": "^7.1.4",
    "serialize-javascript": "^7.0.6",
    "xxhash-wasm": "^1.1.0"
  }
}
