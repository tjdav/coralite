{
  "compilerOptions": {
    "checkJs": true,
    "rootDir": ".",
    "allowJs": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "declarationMap": true,
    "module": "nodenext",
    "target": "ES2022",
    "strict": false,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "paths": {
      "#lib": [
        "./lib/index.js"
      ],
      "#plugins": [
        "./plugins/index.js"
      ]
    },
    "types": ["node"]
  },
  "include": [
    "lib/index.js"
  ],
  "exclude": [
    "tests",
    "node_modules"
  ]
}