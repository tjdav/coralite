{
  "name": "coralite-monorepo",
  "private": true,
  "license": "MPL-2.0",
  "type": "module",
  "homepage": "https://coralite.dev/",
  "repository": {
    "type": "git",
    "url": "git@codeberg.org/tjdavid/coralite.git"
  },
  "keywords": [
    "frontend",
    "ssg-tool",
    "dev-server",
    "build-tool",
    "coralite"
  ],
  "author": {
    "name": "Thomas David",
    "url": "https://thomasjackdavid.com"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "format": "eslint --cache --fix .",
    "lint": "eslint --cache .",
    "test-unit": "pnpm -r --if-present --workspace-concurrency=1 run test-unit",
    "test-e2e": "pnpm --filter coralite run test-e2e",
    "build": "pnpm --filter coralite run build",
    "build-scripts": "pnpm --filter coralite-scripts run build",
    "publish": "pnpm run build && pnpm --filter='./packages/coralite' publish",
    "publish-scripts": "pnpm run build-scripts && pnpm --filter='./packages/coralite-scripts' publish",
    "publish-create": "pnpm --filter='./packages/create-coralite' publish",
    "release": "coralite-release",
    "release-post": "coralite-release-post",
    "release-changelog": "coralite-release-changelog",
    "changelog": "coralite-changelog",
    "website-build": "pnpm --filter='./website' run build",
    "website-dev": "pnpm --filter='./website' run start"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.4.0",
    "@types/node": "^22.18.5",
    "coralite-release": "workspace:*",
    "esbuild": "^0.25.9",
    "eslint": "^9.38.0",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-jsdoc": "^62.9.0",
    "lint-staged": "^17.0.2",
    "premove": "^4.0.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "pre-push": "pnpm --filter coralite run build-types"
  },
  "lint-staged": {
    "packages/**/*.js": [
      "eslint --cache --fix"
    ]
  },
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "dependencies": {
    "dom-serializer": "^2.0.0"
  }
}
